# ===========================================================================
# Last Minute Pilot — Environment Variables
# ===========================================================================
# Copy this file to .env.local (for local dev) or set these in your hosting
# platform's dashboard (Vercel, etc.). Replace every placeholder below with
# your real values. See DEPLOYMENT.md for step-by-step instructions.
# ===========================================================================

# ---------------------------------------------------------------------------
# Database (Supabase Postgres)
# ---------------------------------------------------------------------------
# Get this from: Supabase Dashboard → Project Settings → Database → Connection string
# Use the "Connection pooling" URL (port 6543) for the app.
# Format: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres"

# Direct connection (bypasses pooler) — used for migrations.
# Same as DATABASE_URL but port 5432 and no pgbouncer. (Using Session Pooler instead of Transaction pooler in case ipv6 doesn't work.)
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ---------------------------------------------------------------------------
# NextAuth.js
# ---------------------------------------------------------------------------
# Generate a random secret: `openssl rand -base64 32` or `bun -e "console.log(crypto.randomBytes(32).toString('base64'))"`
NEXTAUTH_SECRET="change this"
# The canonical URL of your deployed app (no trailing slash):
# - Local dev:  http://localhost:3000
# - Production: https://your-domain.com
NEXTAUTH_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# OAuth Providers (NextAuth)
# ---------------------------------------------------------------------------
# Google OAuth — https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 Client ID → Authorized redirect URI:
#   https://your-domain.com/api/auth/callback/google
#   (and http://localhost:3000/api/auth/callback/google for dev)
GOOGLE_CLIENT_ID="REPLACE_WITH_GOOGLE_OAUTH_CLIENT_ID"
GOOGLE_CLIENT_SECRET="REPLACE_WITH_GOOGLE_OAUTH_CLIENT_SECRET"

# GitHub OAuth — https://github.com/settings/developers
# Create OAuth App → Authorization callback URL:
#   https://your-domain.com/api/auth/callback/github
GITHUB_CLIENT_ID="REPLACE_WITH_GITHUB_OAUTH_CLIENT_ID"
GITHUB_CLIENT_SECRET="REPLACE_WITH_GITHUB_OAUTH_CLIENT_SECRET"

# ---------------------------------------------------------------------------
# AI Providers (Gemini primary + Groq fallback)
# ---------------------------------------------------------------------------
# Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY="REPLACE_WITH_GEMINI_API_KEY"

# Groq — https://console.groq.com/keys
GROQ_API_KEY="REPLACE_WITH_GROQ_API_KEY"

# ---------------------------------------------------------------------------
# Google Calendar API (read busy slots + write planned blocks)
# ---------------------------------------------------------------------------
# Uses the same GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET as NextAuth above.
# The OAuth scopes are requested in src/lib/auth.ts (calendar.events scope).
# No additional env vars needed — tokens are stored per-user in the User table.

# ---------------------------------------------------------------------------
# Web Push (VAPID keys)
# ---------------------------------------------------------------------------
# Generate with: `bun run generate-vapid-keys` (one-time setup)
# Or:  npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY="REPLACE_WITH_VAPID_PUBLIC_KEY"
VAPID_PRIVATE_KEY="REPLACE_WITH_VAPID_PRIVATE_KEY"
# Used in the push payload's "subject" field — must be a mailto: or https: URL
VAPID_SUBJECT="mailto:you@example.com"

# ---------------------------------------------------------------------------
# Cron job security (background replanning)
# ---------------------------------------------------------------------------
# Generate a random secret: `openssl rand -hex 32`
# The external cron job (cron-job.org) sends this in the Authorization header:
#   Authorization: Bearer YOUR_CRON_SECRET
CRON_SECRET="REPLACE_WITH_RANDOM_HEX_SECRET"

# ---------------------------------------------------------------------------
# App config
# ---------------------------------------------------------------------------
# Set to "production" when deployed. Affects NextAuth cookie security.
NODE_ENV="development"

# ---------------------------------------------------------------------------
# Local development fallback (SQLite)
# ---------------------------------------------------------------------------
# For local dev WITHOUT Supabase, the app can fall back to a SQLite file.
# The schema is in prisma/schema.dev.prisma. To use it:
#   1. Set DATABASE_URL below to a file path
#   2. Run: bun run db:push:dev
#   3. The app will use SQLite for all queries.
# When you're ready to use Supabase, comment this out and use the DATABASE_URL
# at the top of this file instead.
#
# DATABASE_URL="file:./db/custom.db"
